# ── 네이버 뉴스 API ──────────────────────────────────────
# https://developers.naver.com/apps/#/list → 애플리케이션 등록
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Google Gemini API ────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── 텔레그램 봇 ──────────────────────────────────────────
# @BotFather로 봇 생성 후 발급받은 토큰
TELEGRAM_BOT_TOKEN=

# ── 관리자 인증 ──────────────────────────────────────────
# /admin 페이지 접근 비밀번호 (충분히 복잡하게 설정)
ADMIN_PASSWORD=

# 세션 쿠키 서명용 비밀키 (운영 환경에서는 64자 이상 랜덤 문자열)
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ── 경로 설정 ────────────────────────────────────────────
# Railway Volume 마운트 경로와 일치시키세요 (기본: /app/data)
DATA_DIR=/app/data
LOG_DIR=/app/logs

# ── 로깅 ─────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
